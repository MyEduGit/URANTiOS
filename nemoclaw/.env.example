# NemoClaw .env.example
# Copy to .env and fill in real values. NEVER commit .env.

# === Project ===
NEMOCLAW_PROJECT_NAME=nemoclaw
NEMOCLAW_DATA_ROOT=./
COMPOSE_PROJECT_NAME=nemoclaw

# === PostgreSQL ===
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nemoclaw
POSTGRES_USER=nemoclaw
POSTGRES_PASSWORD=change_me_strong_password

# === Redis (queue + event bus) ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password
REDIS_DB=0
REDIS_QUEUE_PREFIX=nemoclaw:queue:
REDIS_EVENTS_CHANNEL=nemoclaw:events

# === n8n ===
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_n8n_password
N8N_ENCRYPTION_KEY=change_me_n8n_encryption_key_min_32_chars
WEBHOOK_URL=http://localhost:5678/

# === Ollama (local LLM runtime) ===
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://ollama:11434

# === Worker keys (NEVER commit real keys) ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# === Audit / governance ===
NEMOCLAW_APPROVAL_GATE_ENABLED=true
NEMOCLAW_AUDIT_LOG_PATH=./logs/audit.log
NEMOCLAW_ARCHIVE_PATH=./archive

# === Networking ===
# Bind only to localhost by default. Public exposure requires explicit human approval.
BIND_ADDRESS=127.0.0.1
